<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/inbuilt_mod_icon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_horizontal"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"
                android:background="@android:color/transparent" />

            <ImageButton
                android:id="@+id/inbuilt_mod_settings"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="end|top"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_settings"
                android:padding="2dp"
                android:tint="@color/on_surface"
                android:alpha="0.6"
                android:contentDescription="@string/settings" />

        </FrameLayout>

        <TextView
            android:id="@+id/inbuilt_mod_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="@color/on_surface"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="@font/misans"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/inbuilt_mod_desc"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_marginTop="2dp"
            android:gravity="center|top"
            android:textColor="@color/on_surface"
            android:textSize="10sp"
            android:fontFamily="@font/misans"
            android:alpha="0.6"
            android:maxLines="2"
            android:ellipsize="end" />

        <ImageButton
            android:id="@+id/remove_inbuilt_button"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_remove_button"
            android:src="@drawable/ic_close"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:tint="@color/error"
            android:contentDescription="@string/remove" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
